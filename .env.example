DB_HOST=your-rds-host.amazonaws.com
DB_PORT=3306
DB_NAME=your_db_name
DB_USER=your_db_username
DB_PASSWORD=your_db_password
LIP_GROUP_ID=your_lip_group_id
SECRET_KEY=generate-with-python-secrets-module
DASHBOARD_PASSWORD=your_secure_password

# Optional — AWS Secrets Manager (overrides DB_HOST/DB_NAME/DB_USER/DB_PASSWORD above)
# AWS_SECRET_NAME=my-app/db-credentials
# AWS_REGION=ap-southeast-2

# Optional — SharePoint OneDrive Upload (Microsoft Graph API)
# SHAREPOINT_TENANT_ID=your-azure-tenant-id
# SHAREPOINT_CLIENT_ID=your-app-registration-client-id
# SHAREPOINT_CLIENT_SECRET=your-client-secret-value
# SHAREPOINT_USER_UPN=user@yourdomain.com
# SHAREPOINT_UPLOAD_PATH=/Monthly Performance Report/Testing
